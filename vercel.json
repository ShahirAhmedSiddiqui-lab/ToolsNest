{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/ai/*.ts": {
      "maxDuration": 60
    },
    "api/compress-pdf.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
