# Server-only Gemini credential used by Vercel Functions.
# Set this in Vercel Project Settings; never prefix it with VITE_.
GEMINI_API_KEY=""

# Optional server-side model override.
GEMINI_MODEL="gemini-2.5-flash"

# Canonical production origin accepted by the AI functions.
APP_ORIGIN="https://your-toolsnest.vercel.app"
